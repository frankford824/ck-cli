{
  "name": "ccli-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "pnpm -r --sort --workspace-concurrency=1 build",
    "dev": "node --conditions source --import tsx apps/cli/src/index.ts",
    "test": "vitest run --testTimeout=30000",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
